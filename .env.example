# GitHub API token for authentication with GitHub repositories
# Replace with your actual GitHub token
GITHUB_TOKEN=your_github_token_here

# Port for the web server (default: 8000)
PORT=8000

# Path to dbt profiles.yml file (default: ~/.dbt/profiles.yml)
DBT_PROFILES_PATH=~/.dbt/profiles.yml

# Target environment to use from profiles.yml (falls back to default target if not found)
DBT_PROFILE_TARGET=pr

# Proxy settings for GitHub API requests (leave empty if not using a proxy)
# Format: protocol://username:password@host:port
# Example: http://user:pass@proxy.example.com:8080
HTTP_PROXY=
HTTPS_PROXY=
